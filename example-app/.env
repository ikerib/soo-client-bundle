APP_ENV=dev
APP_SECRET=change-me-in-production-32chars!!

# ── SSO Municipal Pasaia ────────────────────────────────────────────────────
# The 4 required env vars for pasaia/sso-client-bundle.

# Base URL of the SSO server (no trailing slash).
SSO_ISSUER_URL=https://sso.pasaia.eus

# Client credentials registered via: php bin/console app:oidc:client:create
SSO_CLIENT_ID=example-app
SSO_CLIENT_SECRET=change-me

# Full URL where the SSO will redirect after authentication.
# Must match the redirect_uri registered in the SSO for this client.
# The path /sso/callback is the default check_path of the drenso firewall.
SSO_REDIRECT_URI=http://localhost:8080/sso/callback
